# =============================================================================
# Docker (recommended — see README "With Docker")
# Copy this file to `.env` in the project root, then run:
#   docker compose up -d --build
# The backend container gets DATABASE_URL from docker-compose.yml (no need to duplicate here).
# Optional: JWT override for the backend service
# =============================================================================
# JWT_SECRET_KEY=change-this-secret-in-production

# =============================================================================
# Manual local dev (no Docker) — use a Postgres on your machine and set:
# =============================================================================
# DATABASE_URL=postgresql://likehome:likehome@127.0.0.1:5432/likehome
# JWT_SECRET_KEY=dev-secret

# Other placeholders (fill if your app uses them)
DB_USERNAME=vampy
DB_PASSWORD=test1
DB_NAME=database-name
SECRET_KEY=your-secret-key
# Your Google OAuth client ID (from console.cloud.google.com)
# Leave empty to disable the "Sign in with Google" button.
GOOGLE_CLIENT_ID=your-google-client-id
