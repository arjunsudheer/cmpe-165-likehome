DB_USERNAME=user
DB_PASSWORD=password
DB_HOST=host
DB_PORT=1234
DB_NAME=database-name 
SECRET_KEY=your-secret-key
DATABASE_URL=postgresql://user:password@host:1234/database-name
FRONTEND_BASE_URL=http://localhost:5173
PASSWORD_RESET_TOKEN_TTL_SECONDS=3600
# Never expose reset tokens in normal environments.
# Only set true when you are explicitly doing local-only debugging.
EXPOSE_RESET_TOKEN_IN_RESPONSE=false
# SMTP settings for password reset emails.
# For Gmail personal accounts, use:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false
# SMTP_USERNAME=your-gmail-address@gmail.com
# SMTP_PASSWORD=your-16-char-app-password
# SMTP_FROM_EMAIL=your-gmail-address@gmail.com
SMTP_HOST=
SMTP_PORT=0
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
# Your Google OAuth client ID (from console.cloud.google.com)
# Leave empty to disable the "Sign in with Google" button.
GOOGLE_CLIENT_ID=your-google-client-id
